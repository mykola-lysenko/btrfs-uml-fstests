 # return the FS mount options of a mounted device
@@ -3545,6 +3559,39 @@
 # Filesystems which don't support this will need to define their
 # own check routine.
 #
+# fsck a fuse2fs-backed device with e2fsck directly: the mounted type is
+# fuse.fuse2fs but the on-disk format is ext4, so neither fsck -t fuse nor
+# the generic mounted-type match in _check_generic_filesystem apply.
+_check_fuse2fs_filesystem()
+{
+    local device=$1
+    local type=`_fs_type $device`
+    local ok=1
+    local mountpoint=""
+
+    case "$type" in
+    fuse*)
+        mountpoint=`_umount_or_remount_ro $device`
+        ;;
+    esac
+
+    e2fsck -fn $device >$tmp.fsck 2>&1
+    if [ $? -ne 0 ]; then
+        _log_err "_check_fuse2fs_filesystem: filesystem on $device is inconsistent"
+        echo "*** e2fsck -fn output ***"	>>$seqres.full
+        cat $tmp.fsck				>>$seqres.full
+        echo "*** end e2fsck output"		>>$seqres.full
+        ok=0
+    fi
+    rm -f $tmp.fsck
+
+    if [ -n "$mountpoint" ]; then
+        _mount_or_remount_rw "$MOUNT_OPTIONS" $device $mountpoint
+    fi
+    [ $ok -ne 0 ] && return 0
+    return 1
+}
+

#!/bin/bash
export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
export TERM=linux
BB=/usr/bin/busybox
$BB mount -t proc proc /proc 2>/dev/null
$BB mount -t sysfs sysfs /sys 2>/dev/null
$BB mount -t devtmpfs devtmpfs /dev 2>/dev/null
$BB ln -sf /proc/self/fd /dev/fd 2>/dev/null
$BB ln -sf /proc/self/fd/0 /dev/stdin 2>/dev/null; $BB ln -sf /proc/self/fd/1 /dev/stdout 2>/dev/null; $BB ln -sf /proc/self/fd/2 /dev/stderr 2>/dev/null
$BB mount -t tmpfs -o size=50% tmpfs /tmp 2>/dev/null
$BB ip link set lo up 2>/dev/null || $BB ifconfig lo 127.0.0.1 up 2>/dev/null
echo "=== QEMU cross-check ($(uname -r)) ==="
cp -a /opt/xfstests /tmp/xfstests 2>/dev/null
cd /tmp/xfstests
MOPTS="$($BB tr ' ' '\n' < /proc/cmdline | $BB sed -n 's/^qmopts=//p' | $BB tr ',' ' ')"
[ -n "$MOPTS" ] && MOPTS="export MOUNT_OPTIONS=\"$MOPTS\""
QFSTYP="$($BB tr ' ' '\n' < /proc/cmdline | $BB sed -n 's/^qfstyp=//p')"
[ -z "$QFSTYP" ] && QFSTYP=btrfs
cat > local.config <<CFG
export FSTYP=$QFSTYP
export TEST_DEV=/dev/vdb
export TEST_DIR=/mnt/test
export SCRATCH_DEV=/dev/vdc
export SCRATCH_MNT=/mnt/scratch
export FSTESTS_PER_TEST_TIMEOUT=900
$MOPTS
CFG
# multi-device tests (raid/scrub): pool over every extra virtio disk present
if [ -b /dev/vdd ]; then
  POOL="/dev/vdc /dev/vdd"
  for d in /dev/vde /dev/vdf /dev/vdg; do [ -b "$d" ] && POOL="$POOL $d"; done
  $BB sed -i '/SCRATCH_DEV=/d' local.config
  echo "export SCRATCH_DEV_POOL=\"$POOL\"" >> local.config
fi
$BB mkdir -p /mnt/test /mnt/scratch
if [ "$QFSTYP" = btrfs ]; then mkfs.btrfs -f /dev/vdb >/dev/null 2>&1; else mkfs.$QFSTYP -Fq /dev/vdb >/dev/null 2>&1; fi
TESTS="$($BB tr ' ' '\n' < /proc/cmdline | $BB sed -n 's/^qtests=//p' | $BB tr ',' ' ')"
[ -z "$TESTS" ] && TESTS="generic/574"
LOOP="$($BB tr ' ' '\n' < /proc/cmdline | $BB sed -n 's/^qloop=//p')"
[ -z "$LOOP" ] && LOOP=1
echo "--- running $TESTS x$LOOP ---"
i=1
while [ "$i" -le "$LOOP" ]; do
  ./check $TESTS > /tmp/iter.log 2>&1
  rc=$?
  fails=$($BB grep -oE 'Failures: .*' /tmp/iter.log)
  echo "QITER $i rc=$rc ${fails:-all-passed}"
  if [ -n "$fails" ]; then
    for f in /tmp/xfstests/results/*/*.out.bad; do
      [ -f "$f" ] || continue
      echo "---- $f ----"; $BB head -25 "$f"
    done
    for f in /tmp/xfstests/results/*/*.full; do
      [ -f "$f" ] || continue
      echo "---- tail $f ----"; $BB tail -15 "$f"
    done
    for f in /tmp/xfstests/results/*/*.dmesg; do
      [ -f "$f" ] || continue
      echo "---- dmesg $f ----"; $BB grep -A40 'cut here' "$f" || $BB tail -40 "$f"
    done
  fi
  i=$((i+1))
done
echo "=== QEMU RUN DONE rc=0 ==="
$BB poweroff -f 2>/dev/null || { echo o > /proc/sysrq-trigger; }

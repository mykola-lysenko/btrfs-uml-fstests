 	} while (res == -EINTR);
 
+	/* Adaptive spin: usually the kernel flips the futex within a few us. */
+	for (int spins = STUB_HANDOFF_SPINS;
+	     spins > 0 && *(volatile unsigned int *)&d->futex == FUTEX_IN_KERN;
+	     spins--)
+		;
+
 	do {
+		if (*(volatile unsigned int *)&d->futex != FUTEX_IN_KERN)
+			break;	/* fast path: peer already handed control back */
 		res = stub_syscall4(__NR_futex, (unsigned long)&d->futex,
 				    FUTEX_WAIT, FUTEX_IN_KERN, 0);
 	} while (res == -EINTR || d->futex == FUTEX_IN_KERN);

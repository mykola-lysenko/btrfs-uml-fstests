--- a/arch/um/include/shared/skas/stub-data.h	2026-06-29 17:03:26.000000000 -0700
+++ b/arch/um/include/shared/skas/stub-data.h	2026-07-02 14:30:38.748385482 -0700
@@ -17,6 +17,17 @@
 #define FUTEX_IN_CHILD 0
 #define FUTEX_IN_KERN 1
 
+/*
+ * EXPERIMENTAL: adaptive spin before FUTEX_WAIT in the stub<->kernel handoff.
+ * A handoff completes in a few microseconds, so spin-checking the shared futex
+ * word first avoids the FUTEX_WAIT syscall and the blocking context switch in
+ * the common case (the peer flips the futex before we exhaust the budget).
+ * FUTEX_WAIT remains the fallback for slow syscalls. 0 disables the spin.
+ */
+#ifndef STUB_HANDOFF_SPINS
+#define STUB_HANDOFF_SPINS 2000000
+#endif
+
 struct stub_init_data {
 	int seccomp;
 

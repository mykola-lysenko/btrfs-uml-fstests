From 922096c6d03b50fd76c8bb6f08d100b8b0a870a1 Mon Sep 17 00:00:00 2001
From: Mykola Lysenko <nickolay.lysenko@gmail.com>
Date: Sun, 12 Jul 2026 16:02:38 -0700
Subject: [PATCH 4/5] btrfs/049: retry when balance completes before it can be
 paused

The test needs a paused balance, but starts balance --bg on a small
filesystem and pauses it a moment later.  On fast setups (and with
recent btrfs, where balance of a lightly-populated fs finishes
quickly) the balance completes before the pause lands and the test
fails with "ERROR: balance pause ... failed: Not running".  The same
race exists twice: once for the paused-balance-across-remount setup
and again in the final pause/resume sanity check.

Retry the start+pause sequence up to five times, adding more block
groups with fsstress between attempts so the balance has enough work
for the pause to win.  The test's intent -- device add must be allowed
while a balance is paused, and pause/resume must work -- is unchanged.

On our test systems the unpatched test fails deterministically against
current btrfs for-next and passes with this change.

Signed-off-by: Mykola Lysenko <nickolay.lysenko@gmail.com>
---
 tests/btrfs/049 | 39 +++++++++++++++++++++++++++++----------
 1 file changed, 29 insertions(+), 10 deletions(-)

diff --git a/tests/btrfs/049 b/tests/btrfs/049
index 5c09942..8164135 100755
--- a/tests/btrfs/049
+++ b/tests/btrfs/049
@@ -41,12 +41,22 @@ args=`_scale_fsstress_args -z \
 echo "Run fsstress $args" >>$seqres.full
 _run_fsstress $args >>$seqres.full
 
-# Start and pause balance to ensure it will be restored on remount
+# Start and pause balance to ensure it will be restored on remount.
+# On fast setups the balance can complete before the pause lands, so retry
+# with more block groups until the pause wins the race.
 echo "Start balance" >>$seqres.full
-_run_btrfs_balance_start --bg "$SCRATCH_MNT"
-$BTRFS_UTIL_PROG balance pause "$SCRATCH_MNT"
-$BTRFS_UTIL_PROG balance status "$SCRATCH_MNT" | grep -q paused
-[ $? -eq 0 ] || _fail "Balance not paused"
+paused=0
+for i in $(seq 1 5); do
+	_run_btrfs_balance_start --bg "$SCRATCH_MNT"
+	$BTRFS_UTIL_PROG balance pause "$SCRATCH_MNT" >>$seqres.full 2>&1
+	if $BTRFS_UTIL_PROG balance status "$SCRATCH_MNT" | grep -q paused; then
+		paused=1
+		break
+	fi
+	echo "balance finished before pause (attempt $i), adding data" >>$seqres.full
+	_run_fsstress $args >>$seqres.full
+done
+[ $paused -eq 1 ] || _fail "Balance not paused"
 
 # Exclusive ops should be blocked on manual pause of balance
 check_exclusive_ops
@@ -71,12 +81,21 @@ $BTRFS_UTIL_PROG balance resume "$SCRATCH_MNT" &>/dev/null
 _run_fsstress $args
 
 # Now pause->resume balance. This ensures balance paused is properly set in
-# the kernel and won't trigger an assertion failure.
+# the kernel and won't trigger an assertion failure. Same start-vs-pause race
+# as above: retry with more block groups until the pause wins.
 echo "Start balance" >>$seqres.full
-_run_btrfs_balance_start --bg "$SCRATCH_MNT"
-$BTRFS_UTIL_PROG balance pause "$SCRATCH_MNT"
-$BTRFS_UTIL_PROG balance status "$SCRATCH_MNT" | grep -q paused
-[ $? -eq 0 ] || _fail "Balance not paused"
+paused=0
+for i in $(seq 1 5); do
+	_run_btrfs_balance_start --bg "$SCRATCH_MNT"
+	$BTRFS_UTIL_PROG balance pause "$SCRATCH_MNT" >>$seqres.full 2>&1
+	if $BTRFS_UTIL_PROG balance status "$SCRATCH_MNT" | grep -q paused; then
+		paused=1
+		break
+	fi
+	echo "balance finished before pause (attempt $i), adding data" >>$seqres.full
+	_run_fsstress $args >>$seqres.full
+done
+[ $paused -eq 1 ] || _fail "Balance not paused"
 $BTRFS_UTIL_PROG balance resume "$SCRATCH_MNT" &>/dev/null
 [ $? -eq 0 ] || _fail "Balance can't be resumed via IOCTL"
 

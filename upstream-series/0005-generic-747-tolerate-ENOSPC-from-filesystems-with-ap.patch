From a423793b584c89b9fcd01acd64d90339371258a9 Mon Sep 17 00:00:00 2001
From: Mykola Lysenko <nickolay.lysenko@gmail.com>
Date: Sun, 12 Jul 2026 16:02:38 -0700
Subject: [PATCH 5/5] generic/747: tolerate ENOSPC from filesystems with
 approximate statfs

The mixed write/delete phase decides whether to write or delete based
on statfs used%, and treats any write failure as fatal.  On btrfs this
fails deterministically: f_bavail counts unallocated chunk space as
available to data at factor 1, while DUP metadata growth consumes it
at 2x, so used% plateaus below the 95% target while the data space is
already exactly full.  The next write then hits ENOSPC and the test
fails -- with the kernel blameless: at the failure instant the data
space_info shows used == total with pinned == 0, i.e. every deleted
byte had already been reclaimed (verified with -o enospc_debug).
ext4, whose statfs is exact, passes the identical test on the same
device.

Treat ENOSPC during the write phases as "filesystem actually full":
drop the partial file and let the loop take the delete branch, which
is precisely the garbage-collection pressure this test exists to
create.  Accounting is unchanged; non-ENOSPC write errors still fail
the test.

Previously 0/10 runs passed on btrfs (UML and KVM, multiple kernel
versions); with this change 3/3 pass and ext4 behaviour is unchanged.

Signed-off-by: Mykola Lysenko <nickolay.lysenko@gmail.com>
---
 tests/generic/747 | 25 ++++++++++++++++++++-----
 1 file changed, 20 insertions(+), 5 deletions(-)

diff --git a/tests/generic/747 b/tests/generic/747
index 4483418..86ade40 100755
--- a/tests/generic/747
+++ b/tests/generic/747
@@ -32,12 +32,24 @@ _create_file() {
 	local file_name=${SCRATCH_MNT}/data_$1
 	local file_sz=$2
 	local dd_extra=$3
+	local out
 
-	POSIXLY_CORRECT=yes dd if=/dev/zero of=${file_name} \
+	out=$(POSIXLY_CORRECT=yes dd if=/dev/zero of=${file_name} \
 		bs=${bs} count=$(( $file_sz / ${bs} )) \
-		status=none $dd_extra  2>&1
+		status=none $dd_extra  2>&1)
 
 	if [ $? -ne 0 ]; then
+		# Filesystems whose statfs is approximate (btrfs: unallocated
+		# space is reported available to data but may be consumed by
+		# metadata growth) can legitimately hit ENOSPC while our
+		# statfs-based fill accounting still reads below the target.
+		# Treat that as "actually full": drop the partial file and let
+		# the caller switch to deleting, which is the point of this GC
+		# stress test anyway.
+		if echo "$out" | grep -q "No space left on device"; then
+			rm -f ${file_name}
+			return 1
+		fi
 		_fail "Failed writing $file_name"
 	fi
 }
@@ -84,9 +96,12 @@ _mixed_write_delete() {
 		if [ $(_used_percent) -lt $fill_percent ]; then
 			local fsz=$(_get_random_fsz)
 
-			_create_file $testseq $fsz "$dd_extra"
-			written_M=$((${written_M} + ${fsz}/${M}))
-			testseq=$((${testseq} + 1))
+			if _create_file $testseq $fsz "$dd_extra"; then
+				written_M=$((${written_M} + ${fsz}/${M}))
+				testseq=$((${testseq} + 1))
+			else
+				_delete_random_file
+			fi
 		else
 			_delete_random_file
 		fi
